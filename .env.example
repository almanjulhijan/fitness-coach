# Strava API credentials
# Get these from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret

# Anthropic API key
# Get this from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# Discord bot token
# Get this from https://discord.com/developers/applications → Bot → Reset Token
DISCORD_BOT_TOKEN=your_discord_bot_token

# Strava refresh token (required for Railway/server deployment — no browser available)
# Run locally first, then copy "refresh_token" value from .tokens.json
STRAVA_REFRESH_TOKEN=your_strava_refresh_token

# Strava webhook (required for real-time activity sync)
# WEBHOOK_VERIFY_TOKEN: pilih string rahasia bebas, e.g. "fitcoach-secret-2026"
# PUBLIC_URL: URL Railway app lo, e.g. "https://fitness-coach-production.up.railway.app"
WEBHOOK_VERIFY_TOKEN=your_secret_verify_token
PUBLIC_URL=https://your-app.up.railway.app

# Post-run analysis enrichment
# Weather data: Open-Meteo (https://open-meteo.com) — gratis, no API key needed
# WAQI (World Air Quality Index): https://aqicn.org/data-platform/token/ (free token, no CC)
WAQI_API_KEY=your_waqi_token
# Discord channel name to post run analysis (default: feed — only set if different)
# POST_RUN_CHANNEL=lari
# Discord category name used to load goals for post-run analysis (default: Running)
# POST_RUN_CATEGORY=Running

# Weekly analysis — channel and category name (defaults: review + Running)
# Only set these if your channel/category names differ from the defaults
# WEEKLY_REVIEW_CHANNEL=review
# WEEKLY_REVIEW_CATEGORY=Running
